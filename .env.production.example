# ===========================================================================
# Pare Engine — Production Environment Configuration
# Owner: S22 (Production Deployment)
# ===========================================================================
#
# Copy this file to .env and fill in ALL required values before deployment.
#
# Deployment target: Hetzner CPX21 + Coolify (~$8-13/mo)
# SSL: Handled by Coolify/Caddy reverse proxy (auto Let's Encrypt)
#
# Keys marked [REQUIRED] must be set for the system to start.
# Keys marked [OPTIONAL] can be added later as features are enabled.
# Keys marked [GENERATED] should be generated using the instructions below.
#
# Canonical schema: packages/core/src/contracts/config.contract.ts
# Loader:           packages/core/src/config.ts
# Docker Compose:   docker-compose.yml
# ===========================================================================

# ===========================================================================
# DATABASE
# ===========================================================================

# [REQUIRED] PostgreSQL credentials for docker-compose
# The compose file builds DATABASE_URL from these values.
POSTGRES_USER=pare
POSTGRES_PASSWORD=                           # [REQUIRED] Strong password (min 16 chars)

# [REQUIRED] Full connection string (used by apps directly)
# In docker-compose, this is auto-constructed. For external DB, set manually.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://pare:YOUR_PASSWORD_HERE@postgres:5432/pare_engine

# ===========================================================================
# ADMIN AUTHENTICATION
# ===========================================================================

# [REQUIRED] Solo operator email address (used for login)
ADMIN_EMAIL=                                 # e.g., arafa@pareconsulting.com

# [REQUIRED] bcrypt hash of the operator password
# Generate with: node -e "const b=require('bcryptjs');b.hash('YOUR_PASSWORD',12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=                         # [GENERATED] bcrypt hash

# [REQUIRED] Session cookie signing secret (min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=                              # [GENERATED] 64-char hex string

# ===========================================================================
# AI ENGINE API KEYS (Tier 1 — Required for audits)
# ===========================================================================

# [REQUIRED] OpenAI — Responses API with web_search tool
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-

# [REQUIRED] Google Gemini — with grounding enabled
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# [REQUIRED] Perplexity — Sonar API (has native citations)
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-

# [REQUIRED] Anthropic — Claude Haiku for analysis/parsing
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-

# ===========================================================================
# CRAWLING (Tier 1 — Required for audits)
# ===========================================================================

# [REQUIRED] Firecrawl — site crawling and content extraction
# https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-

# ===========================================================================
# INNGEST (Durable Pipeline Execution)
# ===========================================================================

# [REQUIRED] Inngest event key (for sending events)
# Generate with: node -e "console.log('evt-' + require('crypto').randomBytes(16).toString('hex'))"
INNGEST_EVENT_KEY=                           # [GENERATED]

# [REQUIRED] Inngest signing key (for verifying webhook signatures)
# Generate with: node -e "console.log('signkey-' + require('crypto').randomBytes(24).toString('base64url'))"
INNGEST_SIGNING_KEY=                         # [GENERATED]

# ===========================================================================
# EMAIL (Tier 2 — Required for report delivery)
# ===========================================================================

# [OPTIONAL until Round 4] Resend — transactional email (3,000/mo free tier)
# https://resend.com/api-keys
RESEND_API_KEY=re_

# ===========================================================================
# GOOGLE APIS (Tier 2 — Optional)
# ===========================================================================

# [OPTIONAL until Round 3] Google Places API — GBP data
# https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# ===========================================================================
# SERP & SEO (Tier 2 — Optional until Round 6)
# ===========================================================================

# [OPTIONAL] Serper.dev — SERP position tracking
# https://serper.dev/
SERPER_API_KEY=

# [OPTIONAL] DataForSEO — backlinks, keywords, AI overview data
# https://dataforseo.com/
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ===========================================================================
# CRM & PAYMENTS (Tier 2 — Optional)
# ===========================================================================

# [OPTIONAL until Round 5] Stripe — payment processing
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# [OPTIONAL] Notion — client management (first 10 clients)
# https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_

# ===========================================================================
# COOLIFY / DEPLOYMENT
# ===========================================================================

# [INFO] These are configured in Coolify's UI, not here.
# Documented for reference:
#
# DOMAIN:          pare.yourdomain.com
# SSL:             Auto (Coolify + Caddy + Let's Encrypt)
# PROXY_PORT:      3000 (Coolify routes HTTPS -> web:3000)
# SERVER:          Hetzner CPX21 (4 vCPU, 8 GB RAM, 80 GB SSD)
# DOCKER_COMPOSE:  Coolify deploys from this docker-compose.yml
#
# Coolify setup:
# 1. Point DNS A record to Hetzner server IP
# 2. Add project in Coolify -> Docker Compose
# 3. Set environment variables in Coolify UI
# 4. Deploy

# ===========================================================================
# NOTES
# ===========================================================================
#
# MCP servers (context7, drizzle, firecrawl, stripe, notion) are
# DEVELOPMENT ONLY. They are NOT started in production. The vendored
# tool stubs in apps/audit-runner/src/tools-vendored/ replace them
# with static typed wrappers.
#
# n8n (self-hosted) runs separately if needed for cron scheduling.
# It fires Inngest events on schedule. It does NOT execute business logic.
#
# For the first deployment:
# 1. Copy this file to .env
# 2. Fill in all [REQUIRED] values
# 3. Generate [GENERATED] values using the commands above
# 4. Run: docker compose up -d
# 5. Run schema migration: docker compose exec web npx drizzle-kit push
# 6. Check logs: docker compose logs -f
# 7. Verify: curl https://your-domain.com/api/health
