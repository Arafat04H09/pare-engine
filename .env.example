# ===========================================================================
# Pare Engine — Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in the values.
# Keys marked [REQUIRED] must be set for the engine to start.
# Keys marked [OPTIONAL] can be added later as features are enabled.
#
# Canonical schema: packages/core/src/contracts/config.contract.ts
# Loader:           packages/core/src/config.ts (loadConfig / loadMinimalConfig)
# ===========================================================================

# --- AI Engine Monitoring (Tier 1 — Required) ---
OPENAI_API_KEY=                       # [REQUIRED] OpenAI Responses API (web_search)
GOOGLE_GENERATIVE_AI_API_KEY=         # [REQUIRED] Gemini with grounding
PERPLEXITY_API_KEY=                   # [REQUIRED] Perplexity Sonar API
ANTHROPIC_API_KEY=                    # [REQUIRED] Claude Haiku for analysis/parsing

# --- Crawling (Tier 1 — Required) ---
FIRECRAWL_API_KEY=                    # [REQUIRED] Firecrawl map + crawl

# --- SERP & SEO (Tier 2 — Optional until Round 6) ---
SERPER_API_KEY=                       # [OPTIONAL] Serper.dev for SERP position tracking
DATAFORSEO_LOGIN=                     # [OPTIONAL] DataForSEO login
DATAFORSEO_PASSWORD=                  # [OPTIONAL] DataForSEO password

# --- Google APIs (Tier 2 — Optional until Round 3) ---
GOOGLE_PLACES_API_KEY=                # [OPTIONAL] Google Places API for GBP data

# --- CRM & Payments (Tier 2 — Optional until Round 5) ---
NOTION_API_KEY=                       # [OPTIONAL] Notion API for client management sync
STRIPE_SECRET_KEY=                    # [OPTIONAL] Stripe secret key
STRIPE_WEBHOOK_SECRET=                # [OPTIONAL] Stripe webhook signing secret

# --- Email (Tier 2 — Optional until Round 4) ---
RESEND_API_KEY=                       # [OPTIONAL] Resend for transactional email (3K/mo free)

# --- Database (Required) ---
DATABASE_URL=postgresql://localhost:5432/pare_engine  # [REQUIRED] PostgreSQL connection string

# --- Admin Auth (Required) ---
ADMIN_EMAIL=                          # [REQUIRED] Operator email address
ADMIN_PASSWORD_HASH=                  # [REQUIRED] bcrypt hash of operator password
SESSION_SECRET=                       # [REQUIRED] Min 32 chars, used for cookie signing

# --- Infrastructure (Optional until Round 4) ---
INNGEST_SIGNING_KEY=                  # [OPTIONAL] Inngest signing key
INNGEST_EVENT_KEY=                    # [OPTIONAL] Inngest event key
